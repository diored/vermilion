<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <RootNamespace>DioRed.Vermilion.Tools.ChatStorageMigrator</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <PropertyGroup>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <Authors>DioRED</Authors>
    <Version>15.1.0</Version>
    <PackageId>DioRed.Vermilion.Tools</PackageId>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>vermilion-tools</ToolCommandName>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageIcon>packageIcon.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageProjectUrl>https://github.com/diored/vermilion</PackageProjectUrl>
    <RepositoryUrl>https://github.com/diored/vermilion.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PackageReleaseNotes>See CHANGELOG.md and MIGRATION.md in the Vermilion repository for release details and upgrade notes.</PackageReleaseNotes>
    <PackageTags>chatbot;bot;tools;migration;storage;dotnet-tool;dotnet;vermilion</PackageTags>
    <Description>Command-line tools for Vermilion. Includes chat storage migration between built-in storage providers.</Description>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\Assets\packageIcon.png" Pack="true" PackagePath="." />
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="DioRed.Common.AzureStorage" Version="4.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Configuration.CommandLine" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.5" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Abstractions\Vermilion.Abstractions.csproj" />
    <ProjectReference Include="..\..\ChatStorage\AzureTable\Vermilion.ChatStorage.AzureTable.csproj" />
    <ProjectReference Include="..\..\ChatStorage\InMemory\Vermilion.ChatStorage.InMemory.csproj" />
    <ProjectReference Include="..\..\ChatStorage\JsonFile\Vermilion.ChatStorage.JsonFile.csproj" />
    <ProjectReference Include="..\..\ChatStorage\MongoDb\Vermilion.ChatStorage.MongoDb.csproj" />
    <ProjectReference Include="..\..\ChatStorage\Sqlite\Vermilion.ChatStorage.Sqlite.csproj" />
    <ProjectReference Include="..\..\ChatStorage\SqlServer\Vermilion.ChatStorage.SqlServer.csproj" />
  </ItemGroup>

</Project>
